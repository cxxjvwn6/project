{
  "buildCommand": "node build.mjs",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/((?!sw\\.js|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ]
}
